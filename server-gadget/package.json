{
  "name": "server-gadget",
  "version": "0.1.0",
  "description": "Crunch Gadget gateway — bridges ESP32-S3 devices to the Crunch platform",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "express": "^4.21.0",
    "ws": "^8.18.0",
    "aedes": "^0.51.0",
    "jsonwebtoken": "^9.0.2",
    "openai": "^4.70.0",
    "axios": "^1.7.0",
    "dotenv": "^16.4.0",
    "uuid": "^10.0.0",
    "cors": "^2.8.5",
    "helmet": "^8.0.0",
    "express-rate-limit": "^7.4.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/ws": "^8.5.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/cors": "^2.8.0",
    "@types/uuid": "^10.0.0",
    "typescript": "^5.6.0",
    "tsx": "^4.19.0",
    "vitest": "^2.1.0",
    "eslint": "^9.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
