# server-gadget environment configuration

# Server
PORT=3004
NODE_ENV=development

# Crunch platform
CRUNCH_API_URL=http://localhost:3000/api/v1
CRUNCH_CHATKIT_URL=http://localhost:8001
CRUNCH_MCP_URL=http://localhost:8787

# OpenAI (for voice proxy — Whisper STT + TTS)
OPENAI_API_KEY=sk-your-key-here

# Device authentication
DEVICE_JWT_SECRET=change-me-to-a-random-secret

# MQTT broker (embedded aedes by default, or external)
MQTT_PORT=1883
# MQTT_BROKER_URL=mqtt://external-broker:1883  # uncomment for external broker

# OTA firmware hosting
OTA_FIRMWARE_PATH=./ota-binaries
